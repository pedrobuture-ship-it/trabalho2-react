{
  "name": "cadastro-clientes-react-api",
  "version": "1.0.0",
  "private": true,
  "description": "Aplicacao ReactJS para cadastro e listagem de clientes consumindo uma API REST.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api": "json-server --watch api/db.json --port 3333",
    "start": "concurrently \"npm run api\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "json-server": "^1.0.0-beta.3",
    "vite": "^6.0.7"
  }
}
